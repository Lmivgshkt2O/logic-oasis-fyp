rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function ownsStudentField() {
      return signedIn() &&
        request.resource.data.studentId == request.auth.uid;
    }

    function ownsExistingStudentField() {
      return signedIn() &&
        resource.data.studentId == request.auth.uid;
    }

    match /topics/{topicId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /questions/{questionId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /questionBanks/{bankId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Correctness and explanations are server-only. Callable quiz-session
    // functions use the Admin SDK and are not constrained by these rules.
    match /questionAnswerKeys/{questionId} {
      allow read, write: if false;
    }

    // U3 session and response documents are created and finalized only by
    // callable Functions through the Admin SDK. The app receives safe return
    // payloads, not direct document access.
    match /quizSessions/{sessionId} {
      allow read, write: if false;
    }

    match /questionResponses/{responseId} {
      allow read, write: if false;
    }

    // U3-R's monotonic sequence is allocated by the callable finalization
    // transaction only. It must never become a client or parent data source.
    match /studentSubtopicSequenceStates/{studentId}/subtopics/{subtopicId} {
      allow read, write: if false;
    }

    match /subtopics/{subtopicId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /users/{userId} {
      allow read, write: if ownsUserDoc(userId);
    }

    match /rememberedProfiles/{profileId} {
      allow read, write: if ownsUserDoc(profileId);
    }

    match /parentAccounts/{parentId} {
      allow read, write: if signedIn();
    }

    match /quizAttempts/{attemptId} {
      allow read: if ownsExistingStudentField();
      allow write: if false;
    }

    match /topicMastery/{masteryId} {
      allow read: if ownsExistingStudentField();
      allow write: if false;
    }

    match /subtopicMastery/{masteryId} {
      allow read: if ownsExistingStudentField();
      allow write: if false;
    }

    match /oasisProgress/{progressId} {
      allow read: if ownsExistingStudentField();
      allow create, update: if ownsStudentField();
      allow delete: if false;
    }

    match /aiModelRuns/{runId} {
      allow read: if ownsExistingStudentField();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
