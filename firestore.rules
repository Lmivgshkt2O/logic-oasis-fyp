rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function ownsStudentField() {
      return signedIn() &&
        request.resource.data.studentId == request.auth.uid;
    }

    function ownsExistingStudentField() {
      return signedIn() &&
        resource.data.studentId == request.auth.uid;
    }

    // U8 exposes only bounded derived projections.  Link creation/revocation
    // is owned by the U9 callable administration flow; this predicate merely
    // enforces a server-created active relationship when it exists.
    function isActiveLinkedParent(studentId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/parentLinks/$(request.auth.uid + '_' + studentId)) &&
        get(/databases/$(database)/documents/parentLinks/$(request.auth.uid + '_' + studentId)).data.status == 'active' &&
        get(/databases/$(database)/documents/parentLinks/$(request.auth.uid + '_' + studentId)).data.parentId == request.auth.uid &&
        get(/databases/$(database)/documents/parentLinks/$(request.auth.uid + '_' + studentId)).data.studentId == studentId;
    }

    function ownsOrActiveLinkedParent(studentId) {
      return signedIn() && (request.auth.uid == studentId || isActiveLinkedParent(studentId));
    }

    match /topics/{topicId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /questions/{questionId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /questionBanks/{bankId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Correctness and explanations are server-only. Callable quiz-session
    // functions use the Admin SDK and are not constrained by these rules.
    match /questionAnswerKeys/{questionId} {
      allow read, write: if false;
    }

    // U3 session and response documents are created and finalized only by
    // callable Functions through the Admin SDK. The app receives safe return
    // payloads, not direct document access.
    match /quizSessions/{sessionId} {
      allow read, write: if false;
    }

    match /questionResponses/{responseId} {
      allow read, write: if false;
    }

    // U3-R's monotonic sequence is allocated by the callable finalization
    // transaction only. It must never become a client or parent data source.
    match /studentSubtopicSequenceStates/{studentId}/subtopics/{subtopicId} {
      allow read, write: if false;
    }

    match /subtopics/{subtopicId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /users/{userId} {
      allow read, write: if ownsUserDoc(userId);
    }

    match /rememberedProfiles/{profileId} {
      allow read, write: if ownsUserDoc(profileId);
    }

    match /parentAccounts/{parentId} {
      // Superseded prototype records included password-derived data. U9 uses
      // Firebase Auth plus the server-owned parentLinks relationship instead.
      allow read, write: if false;
    }

    match /quizAttempts/{attemptId} {
      allow read: if ownsExistingStudentField();
      allow write: if false;
    }

    match /topicMastery/{masteryId} {
      allow read: if ownsExistingStudentField();
      allow write: if false;
    }

    match /subtopicMastery/{masteryId} {
      allow read: if ownsOrActiveLinkedParent(resource.data.studentId);
      allow write: if false;
    }

    match /studentAiStatuses/{attemptId} {
      allow read: if ownsOrActiveLinkedParent(resource.data.studentId);
      allow write: if false;
    }

    match /adaptiveAssignments/{assignmentId} {
      allow read: if ownsOrActiveLinkedParent(resource.data.studentId);
      allow write: if false;
    }

    // U10 will own this deliberately count-only projection. U9 reserves the
    // safe read surface now; forum text, identities and moderation data have
    // no client-readable rule.
    match /forumParticipationSummaries/{studentId} {
      allow read: if ownsOrActiveLinkedParent(studentId);
      allow write: if false;
    }

    match /oasisProgress/{progressId} {
      allow read: if ownsExistingStudentField();
      allow create, update: if ownsStudentField();
      allow delete: if false;
    }

    match /aiModelRuns/{runId} {
      // Includes raw feature values and SHAP arrays; always server-only.
      allow read, write: if false;
    }

    match /aiJobs/{attemptId} {
      allow read, write: if false;
    }

    match /masterySnapshots/{snapshotId} {
      allow read, write: if false;
    }

    match /modelRegistry/{modelId} {
      allow read, write: if false;
    }

    match /parentLinks/{linkId} {
      // Clients cannot establish, reactivate, update, delete, or inspect
      // relationships. U9's audited callable administration flow uses Admin
      // SDK writes and is intentionally outside Rules.
      allow write: if false;
      allow read: if false;
    }

    match /adminRoleAudits/{auditId} {
      allow read, write: if false;
    }

    match /parentLinkAudits/{auditId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
